{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "components/AboutPreview.tsx",
    "components/AreaPageTemplate.tsx",
    "components/BlogPreviewSection.tsx",
    "components/CTASticky.tsx",
    "components/Contact.tsx",
    "components/FAQ.tsx",
    "components/FloatingWhatsApp.tsx",
    "components/Gallery.tsx",
    "components/Hero.tsx",
    "components/JantSalesSection.tsx",
    "components/PageHero.tsx",
    "components/ProcessSteps.tsx",
    "components/RegionDirectory.tsx",
    "components/SeoJsonLd.tsx",
    "components/ServiceAreas.tsx",
    "components/ServicePageTemplate.tsx",
    "components/Services.tsx",
    "components/VehicleTypes.tsx",
    "components/WhyChooseUs.tsx",
    "data/blog-posts.ts",
    "lib/content.ts",
    "lib/site.ts"
  ]
}
